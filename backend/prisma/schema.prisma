generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  username          String              @db.VarChar(50)
  email             String              @db.VarChar(100)
  google_id         String?             @db.VarChar(255)
  github_id         String?             @db.VarChar(255)
  password          String?             @db.VarChar(255)
  fullName          String?             @db.VarChar(255)
  avatar            String?             @db.VarChar(255)
  roles_id          Int
  status            users_status?       @default(active)
  created_at        DateTime?           @default(now()) @db.Timestamp(0)

  // ความสัมพันธ์ฝั่ง HR
  hr_profile        hr_profiles?
  hr_activities     hr_activities[]

  // ความสัมพันธ์ฝั่ง Seeker (เพิ่มใหม่)
  seeker_profile    seeker_profiles?
  seeker_activities seeker_activities[]

  // ความสัมพันธ์อื่น ๆ
  resumes           resumes[]
  audit_logs        audit_logs[]
  Job               Job[]
  applications      JobApplication[]
  saved_jobs        saved_jobs[]
  interviews        interviews[]
  roles             roles               @relation(fields: [roles_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([roles_id], map: "roles_id")
  @@map("users")
}

model seeker_profiles {
  user_id   Int      @id
  bio       String?  @db.Text
  location  String?  @db.VarChar(255)
  education String?  @db.VarChar(255)
  interests String?  @db.VarChar(255)
  views     Int      @default(0)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("seeker_profiles")
}

model seeker_activities {
  id         Int      @id @default(autoincrement())
  seeker_id  Int
  text       String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamp(0)
  user       User     @relation(fields: [seeker_id], references: [id], onDelete: Cascade)

  @@map("seeker_activities")
}

model hr_profiles {
  user_id      Int      @id
  company      String?  @db.VarChar(255)
  bio          String?  @db.Text
  website      String?  @db.VarChar(255)
  location     String?  @db.VarChar(255)
  industry     String?  @db.VarChar(100)
  company_desc String?  @db.Text
  company_size String?  @db.VarChar(50)
  founded      String?  @db.VarChar(20)
  role         String?  @default("HR Recruiter") @db.VarChar(100)
  about_items  Json?

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("hr_profiles")
}

model hr_activities {
  id         Int      @id @default(autoincrement())
  hr_id      Int
  text       String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamp(0)

  user       User     @relation(fields: [hr_id], references: [id], onDelete: Cascade)
  @@map("hr_activities")
}

model audit_logs {
  id         Int       @id @default(autoincrement())
  admin_id   Int
  action     String    @db.VarChar(100)
  target_id  Int?
  detail     String?   @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(0)
  users      User      @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id], map: "admin_id")
}

model resumes {
  id          Int                 @id @default(autoincrement())
  user_id     Int
  title       String?             @default("My Resume") @db.VarChar(100)
  template    String?             @default("modern") @db.VarChar(50)
  visibility  resumes_visibility? @default(private)
  
  // ยุบรวมข้อมูลจาก sections
  summary     String?             @db.Text
  experience  Json?    
  education   Json?    
  skills      Json?    
  
  created_at  DateTime?           @default(now()) @db.Timestamp(0)
  updated_at  DateTime?           @default(now()) @updatedAt @db.Timestamp(0) 

  users       User                @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "user_id")
  @@map("resumes")
}

enum resumes_visibility {
  public
  private
}

model roles {
  id    Int    @id
  name  String @unique(map: "name") @db.VarChar(50)
  level String @unique(map: "level") @db.VarChar(100)
  users User[]
}

model system_settings {
  id                   Int      @id
  max_file_size        BigInt?  @default(10485760)
  maintenance_mode     Boolean? @default(false)
  max_resumes_per_user Int      @default(5)
  allow_registration   Boolean  @default(true)
  auto_approve_hr      Boolean  @default(false)
}

enum users_status {
  active
  suspended
  banned
  pending
}

model Job {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  category     String   @db.VarChar(100)
  job_type     String   @db.VarChar(50)
  location     String   @db.VarChar(255)
  salary       String   @db.VarChar(100)
  experience   String   @db.VarChar(100)
  description  String   @db.Text
  requirements String   @db.Text
  benefits     String   @db.Text
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  status       String   @default("เปิดรับสมัคร") @db.VarChar(50)
  applications JobApplication[]
  saved_jobs   saved_jobs[]
  
  hrId         Int
  users        User     @relation(fields: [hrId], references: [id], onDelete: Cascade)

  @@index([hrId], map: "hrId_idx")
}

model JobApplication {
  id           Int      @id @default(autoincrement())
  jobId        Int
  seekerId     Int
  appliedAt    DateTime @default(now()) @db.Timestamp(0)
  status       String   @default("pending") @db.VarChar(50) // เช่น pending, interviewing, rejected

  // Relation
  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker User @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([seekerId])
  @@map("job_applications")
}
model saved_jobs {
  id         Int      @id @default(autoincrement())
  hr_id      Int
  job_id     Int
  created_at DateTime @default(now()) @db.Timestamp(0)

  user       User     @relation(fields: [hr_id],  references: [id], onDelete: Cascade)
  job        Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@unique([hr_id, job_id])
  @@map("saved_jobs")
}

model interviews {
  id               Int       @id @default(autoincrement())
  hr_id            Int
  job_id           Int?
  candidate_name   String?   @db.VarChar(255)
  job_title        String?   @db.VarChar(255)
  interview_date   DateTime? @db.Date
  interview_time   String?   @db.VarChar(20)
  interview_type   String?   @default("Online") @db.VarChar(50)
  interviewer      String?   @db.VarChar(255)
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  user             User      @relation(fields: [hr_id], references: [id], onDelete: Cascade)

  @@map("interviews")
}
